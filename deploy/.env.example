# =============================================================================
# Find And Study OS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# Required variables are marked with [REQUIRED].
# =============================================================================

# --- Core ---
NODE_ENV=production
PORT=3000

# --- Database [REQUIRED] ---
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/findandstudy_db

# --- CORS / Allowed Origins [REQUIRED] ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Frontend Static Files (optional) ---
# Override the default frontend dist path if your layout differs
# FRONTEND_DIST_PATH=/var/www/findandstudy/artifacts/edcons/dist/public

# --- Session / Auth ---
# Secret for signing session cookies (generate a random 64-char string)
SESSION_SECRET=change-me-to-a-random-64-character-string

# --- Object Storage (optional) ---
# If using Google Cloud Storage for file uploads
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
# PRIVATE_OBJECT_DIR=private
# PUBLIC_OBJECT_SEARCH_PATHS=public

# --- Email (optional) ---
# SMTP settings for sending emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# --- AI Features (optional) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
