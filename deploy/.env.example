# EduConsult OS — Ortam Değişkenleri Örneği
# Bu dosyayı kopyalayın: cp deploy/.env.example .env
# Tüm <degistir> ifadelerini gerçek değerlerle doldurun.
#
# GÜVENLİK: .env dosyasını asla git'e eklemeyin (zaten .gitignore'da).

# ===========================================================================
# ZORUNLU — Bu değerler olmadan uygulama başlamaz
# ===========================================================================

# PostgreSQL bağlantı dizisi [ZORUNLU]
DATABASE_URL=postgresql://<kullanici>:<sifre>@localhost:5432/<veritabani>

# Uygulama portu — nginx upstream ile eşleşmeli (deploy/nginx.conf → 5000)
PORT=5000

# Node.js ortamı
NODE_ENV=production

# Session şifreleme anahtarı [ZORUNLU] — üret: openssl rand -hex 32
SESSION_SECRET=<degistir-openssl-rand-hex-32>

# Veritabanı alan şifreleme anahtarı [ZORUNLU] — üret: openssl rand -hex 32
ENCRYPTION_KEY=<degistir-openssl-rand-hex-32>

# Embed widget JWT anahtarı [ZORUNLU] — üret: openssl rand -hex 32
EMBED_TOKEN_SECRET=<degistir-openssl-rand-hex-32>

# ===========================================================================
# KORSLAR & ERIŞIM URL'LERİ (ÖNERİLEN)
# ===========================================================================

# İzin verilen frontend origin'leri (virgülle ayrılmış) [ÖNERİLEN]
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Uygulamanın dış URL'i — e-posta ve PDF linklerinde kullanılır [ÖNERİLEN]
APP_BASE_URL=https://yourdomain.com

# ===========================================================================
# WHATSAPP BUSINESS API
# ===========================================================================

# WhatsApp Cloud API erişim tokeni [WA entegrasyonu için zorunlu]
WA_ACCESS_TOKEN=<degistir>

# WhatsApp webhook imzası doğrulama için uygulama secret'i [WA entegrasyonu için zorunlu]
WA_APP_SECRET=<degistir>

# Canlı entegrasyonları etkinleştir (WhatsApp gönderimi, e-posta iletimi)
# Production: true | Staging/test: false
ALLOW_LIVE_INTEGRATIONS=true

# ===========================================================================
# NESNE DEPOLAMA
# ===========================================================================

# Özel nesneler için yerel depolama dizini (belge yüklemeleri, imza dosyaları)
PRIVATE_OBJECT_DIR=/var/www/edconsult-os/storage/private

# Kamuya açık nesneler için arama yolları (virgülle ayrılmış)
PUBLIC_OBJECT_SEARCH_PATHS=/var/www/edconsult-os/storage/public

# ===========================================================================
# FRONTEND & YOLLAR
# ===========================================================================

# Derlenmiş frontend dizini — build sonrası otomatik oluşur, genellikle değiştirmeyin
# FRONTEND_DIST_PATH=./artifacts/edcons/dist/public

# ===========================================================================
# PDF OLUŞTURMA (Sözleşme PDF'leri — headless Chromium gerektirir)
# ===========================================================================

# Headless Chromium çalıştırılabilir dosya yolu
# Kurulum: npx playwright install chromium
# Ubuntu tipik yolu: /home/<kullanici>/.cache/ms-playwright/chromium-*/chrome-linux/chrome
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/home/<kullanici>/.cache/ms-playwright/chromium-1161/chrome-linux/chrome

# ===========================================================================
# VERİTABANI BAĞLANTI HAVUZU (opsiyonel — varsayılanlar genellikle yeterli)
# ===========================================================================

# DB_POOL_MAX=10
# DB_CONNECT_TIMEOUT_MS=10000
# DB_IDLE_TIMEOUT_MS=30000
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_QUERY_TIMEOUT_MS=30000
# DB_QUERY_RETRIES=3
# DB_RETRY_BASE_MS=500

# ===========================================================================
# YAPAY ZEKA (opsiyonel — AI içerik önerileri için)
# ===========================================================================

# Anthropic Claude API anahtarı
# ANTHROPIC_API_KEY=<degistir>

# ===========================================================================
# İLK KURULUM — Yalnızca ilk deploy'da kullanılır, sonra kaldırın/yoruma alın
# ===========================================================================

# İlk admin kullanıcısı için geçici şifre (giriş yaptıktan sonra değiştirin)
# SEED_ADMIN_PASSWORD=<degistir>

# İlk agent kullanıcısı için geçici şifre
# SEED_AGENT_PASSWORD=<degistir>
