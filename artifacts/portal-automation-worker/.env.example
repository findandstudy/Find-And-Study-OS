# Portal Automation Worker — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/edcons

# ─── Worker identity ────────────────────────────────────────────────────────
WORKER_ID=portal-worker-1
POLL_INTERVAL_MS=5000
MAX_CONCURRENT_JOBS=2

# ─── Playwright / Chromium ──────────────────────────────────────────────────
# Set to true to show browser window (dev/debug only)
PORTAL_HEADLESS=true
PORTAL_TIMEOUT_MS=60000
SCREENSHOT_ON_FAILURE=true
SCREENSHOTS_DIR=./screenshots

# ─── GCS / Object storage (optional) ───────────────────────────────────────
# GCS_BUCKET=your-bucket-name
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Portal adapter credentials ─────────────────────────────────────────────
# Format: <ADAPTER_KEY_UPPERCASE>_EMAIL and <ADAPTER_KEY_UPPERCASE>_PASSWORD
# Example for adapter key "topkapi":

# TOPKAPI_EMAIL=portal-automation@example.com
# TOPKAPI_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# Example for adapter key "sit":
# SIT_EMAIL=portal-automation@example.com
# SIT_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# Example for adapter key "united":
# UNITED_EMAIL=portal-automation@example.com
# UNITED_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# Example for Salesforce adapters (uses USER instead of EMAIL):
# SALESFORCE_USER=portal-automation@example.com
# SALESFORCE_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# Add one pair per active portal adapter. Key must match the adapter's key
# in ALL_CAPS with hyphens replaced by underscores.
