# =============================================================================
# Find & Study — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values.
# Lines marked [REQUIRED] MUST be set in production.
# Lines marked [OPTIONAL] have safe defaults or are feature-specific.
# Lines marked [BUILD-TIME] are only needed during `pnpm build`, not at runtime.
# Lines marked [REPLIT-ONLY] are auto-injected by Replit — not needed on Hostinger.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# On Hostinger: create a Postgres DB in hPanel and copy the connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/findandstudy


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# [REQUIRED] Node.js environment. Must be "production" on live server.
NODE_ENV=production

# [OPTIONAL] Port the API server listens on. Default: 5000.
# Nginx reverse-proxies to this port, so usually no need to change.
PORT=5000

# [REQUIRED] Comma-separated list of allowed CORS origins (no trailing slash).
# Must include your production domain(s).
# Example: https://findandstudy.com,https://www.findandstudy.com
ALLOWED_ORIGINS=https://findandstudy.com,https://www.findandstudy.com


# -----------------------------------------------------------------------------
# AI — PASSPORT / DOCUMENT SCANNING
# -----------------------------------------------------------------------------

# [REQUIRED for AI scanning] Anthropic Claude API key.
# Used for AI-powered passport recognition and document extraction.
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...


# -----------------------------------------------------------------------------
# OBJECT STORAGE (File Uploads)
# -----------------------------------------------------------------------------

# [OPTIONAL] Comma-separated paths that are publicly accessible.
# Default: empty (no public paths).
# Example: uploads/public,uploads/logos
PUBLIC_OBJECT_SEARCH_PATHS=

# [OPTIONAL] Absolute path on disk for private file storage.
# Default: empty (uses in-memory / DB storage).
# Example: /var/www/findandstudy/storage/private
PRIVATE_OBJECT_DIR=

# [RECOMMENDED] Canonical public origin of the deployed app, used to absolutize
# relative asset URLs (student photo / documents) sent to external create
# webhooks (e.g. SIT n8n). Must be a public https origin reachable by the
# webhook — no trailing slash. If unset in production the SIT adapter falls back
# to https://apply.findandstudy.com, but set this explicitly to be safe.
# Example: https://apply.findandstudy.com
PUBLIC_APP_BASE=


# -----------------------------------------------------------------------------
# SEEDING — Initial Data (Run Once)
# -----------------------------------------------------------------------------

# [OPTIONAL] Password for the automatically seeded super-admin account.
# Only used on first startup if no admin user exists.
# Remove or leave empty after first run.
SEED_ADMIN_PASSWORD=

# [OPTIONAL] Password for the automatically seeded demo agent account.
# Only used on first startup if no agent exists.
# Remove or leave empty after first run.
SEED_AGENT_PASSWORD=


# -----------------------------------------------------------------------------
# BUILD-TIME — Frontend (pnpm build)
# -----------------------------------------------------------------------------

# [BUILD-TIME] Canonical site URL used in sitemap.xml and OG meta tags.
# Default: https://findandstudy.com
BASE_URL=https://findandstudy.com

# [BUILD-TIME] Vite base path if the app is served from a sub-path.
# Default: / (root). Change only if deploying to a subdirectory.
BASE_PATH=/


# -----------------------------------------------------------------------------
# REPLIT-ONLY — Auto-injected by Replit platform (do NOT set on Hostinger)
# -----------------------------------------------------------------------------

# [REPLIT-ONLY] Used for CORS allowlisting in development.
# REPLIT_DEV_DOMAIN=

# [REPLIT-ONLY] Used for CORS and email base URL detection.
# REPLIT_DOMAINS=

# [REPLIT-ONLY] Used for email base URL in transactional emails.
# REPLIT_DEPLOYMENT_URL=

# [REPLIT-ONLY] Replit platform identifier. Triggers dev-mode CORS.
# REPL_ID=


# -----------------------------------------------------------------------------
# PORTAL ADAPTERS — University application portal credentials
# Set real values in .env (never commit .env); this file contains keys only.
# -----------------------------------------------------------------------------

# SIT Portal (11 universities: Halic, Atlas, Ankara Medipol, Galata,
#             Istanbul Yeni Yuzyil, Istinye, Istanbul Aydin, Istanbul Kent,
#             Fenerbahce, Istanbul Kultur, TED)
SIT_USER=
SIT_PASSWORD=

# United Portal (Biruni, Nisantasi, Ankara Bilim)
UNITED_USER=
UNITED_PASSWORD=

# İstanbul Topkapı Üniversitesi
TOPKAPI_USER=
TOPKAPI_PASSWORD=

# Üsküdar Üniversitesi (Salesforce / apply.uskudar.edu.tr)
USKUDAR_EMAIL=
USKUDAR_PASSWORD=

# Additional Salesforce-based schools — uncomment when onboarded:
# OKAN_EMAIL=
# OKAN_PASSWORD=


# -----------------------------------------------------------------------------
# PORTAL AUTOMATION WORKER
# Settings for the findandstudy-portal-worker PM2 process.
# These are consumed by artifacts/portal-automation-worker/src/worker.ts.
# -----------------------------------------------------------------------------

# [OPTIONAL] Polling interval in ms when the submission queue is empty.
# Default: 5000 (5 seconds). Increase on low-traffic servers to reduce CPU.
WORKER_POLL_MS=5000

# [OPTIONAL] Stale-lock threshold in ms. Submissions locked longer than this
# are forcibly released on the next tick (crash recovery). Default: 300000 (5 min).
WORKER_STALE_MS=300000

# [OPTIONAL] Set to "true" to force Chromium headless mode in the worker.
# The browser is always launched headless regardless of this value; the flag
# is documented here for clarity and future overrides.
PLAYWRIGHT_HEADLESS=true

# [OPTIONAL] Absolute path to a Playwright storageState directory for
# persisting browser auth sessions across worker restarts (reduces re-logins).
# Example: /var/www/findandstudy/auth
# Leave empty to disable session persistence.
AUTH_STATE_DIR=

# [OPTIONAL] Absolute path to the Chromium executable.
# Leave empty on VPS — Playwright will use the Chromium it downloads.
# On Replit: set automatically via PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH in .replit.
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=

# [REQUIRED for portal credential DB encryption]
# 32+ character secret used to encrypt/decrypt portal credentials stored in the
# portal_credentials table (AES-256-GCM). Must match the value used by the
# API server's ENCRYPTION_KEY (they share the same secret).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
